# ──────────────────────────────────────────────────────────────
# Environment variables. Copy this file to `.env.local` and fill in values.
# `.env.local` is gitignored — never commit real secrets.
#
# Convention: `VITE_`-prefixed vars are bundled into the client and are safe
# to expose (public IDs/DSNs). All other vars are server-only.
# ──────────────────────────────────────────────────────────────

# ── Neon (Postgres database) ──────────────────────────────────
# Auto-created by Neon Launchpad: https://neon.new
# Pooled connection string (pgBouncer) used at runtime:
DATABASE_URL=
# Direct connection used for migrations:
DATABASE_URL_POOLER=

# ── Sentry (error monitoring) ─────────────────────────────────
# Client-exposed (public DSN is safe to expose):
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
# SERVER/CI ONLY — secret auth token. Do not expose to the client.
SENTRY_AUTH_TOKEN=

# ── WorkOS (authentication, client-side AuthKit) ──────────────
# Client-exposed. NOTE: src/integrations/workos/provider.tsx THROWS at boot
# if VITE_WORKOS_CLIENT_ID is empty, so set it (even a placeholder) for the
# app to start. Real value from your WorkOS dashboard: https://workos.com
VITE_WORKOS_CLIENT_ID=
VITE_WORKOS_API_HOSTNAME=api.workos.com

# ── SerpAPI (server-side only) ────────────────────────────────
# Used ONLY inside server functions (src/server/serpapi.ts). Engine: google.
# Get a key: https://serpapi.com/manage/api-key
SERPAPI_API_KEY=

# ── Unkey (server-side only) ──────────────────────────────────
# Used ONLY inside server functions (src/server/unkey.ts).
# This project uses API-key verification via @unkey/api.
UNKEY_API_KEY=

# ── Electric (platform-level, not wired up yet) ───────────────
# See docs/integrations/electric.md. Client-visible Electric service URL,
# set only when you adopt Electric:
VITE_ELECTRIC_SERVICE_URL=

# ── AG Grid ───────────────────────────────────────────────────
# This project uses AG Grid Community (no key needed). Only set this if you
# switch to AG Grid Enterprise AND obtain a license:
# AG_GRID_ENTERPRISE_LICENSE_KEY=
