# Registry mirror.
# This environment reaches the internet through a local proxy (127.0.0.1:7897).
# Through it the official registry.npmjs.org is slow and drops connections
# (npm ECONNRESET). registry.npmmirror.com is a full, fast mirror and is used by
# both npm/npx and `bun install` (bun reads .npmrc).
#
# To go back to the official registry, delete this file or set:
#   registry=https://registry.npmjs.org/
registry=https://registry.npmmirror.com/
